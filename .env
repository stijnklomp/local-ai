# .env  — shared by docker-compose and the hook scripts
# Copy this to your project root alongside docker-compose.yml

# Neo4j credentials (must match NEO4J_AUTH in docker-compose.yml)
NEO4J_PASSWORD=password

# Hook connection settings (used inside the Docker Sandbox by the plugin)
HOOKS_NEO4J_URI=bolt://host.docker.internal:7687
HOOKS_NEO4J_USER=neo4j
HOOKS_NEO4J_PASSWORD=password
