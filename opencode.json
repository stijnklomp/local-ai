{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["./plugins/agentmemory-capture.ts"],
  "instructions": [
    "~/.config/opencode/skills/docker-runtime/SKILL.md",
    "~/.config/opencode/skills/git-workflow/SKILL.md",
    "CRITICAL: When calling agentmemory MCP tools, always provide 'concepts' and 'files' as explicit structured arrays, never as flat strings or comma-separated text."
  ],
  "model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "agentmemory": {
      "type": "local",
      "command": ["agentmemory", "mcp"],
      "environment": {
        "AGENTMEMORY_URL": "http://127.0.0.1:3111"
      },
      "enabled": true
    }
  },
  "provider": {
    "opencode-go": {
      "models": {
        "deepseek-v4-flash": {
          "options": {
            "reasoningEffort": "max"
          }
        }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://172.17.0.1:11434/v1"
      },
      "models": {
        "mistral-nemo:12b": {
          "name": "Mistal Nemo (12B) General (Nvidia GPU optimized)"
        },
        "qwen2.5-coder:14b": {
          "name": "Qwen 2.5 (14B) Coding"
        },
        "qwen2.5:14b": {
          "name": "Qwen 2.5 (14B) General"
        },
        "deepseek-r1:32b": {
          "name": "Deepseek (32B) Reasoning"
        }
      }
    }
  },
  "enabled_providers": [
    "ollama",
    "opencode",
    "opencode-go"
  ],
  "autoupdate": false
}
